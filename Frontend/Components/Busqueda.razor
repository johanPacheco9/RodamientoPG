@using Domain.Models.Vehiculos
@using Domain.Models.Vehiculos.Requests
@using Infrastructure.Services.Vehiculos
@using Infrastructure.Services.Vehiculos.Responses 
@inject VehiculosService VehiculosService;
@inject BusquedaService BusquedaService;
@inject IJSRuntime JsRuntime
@rendermode InteractiveServer

<div class="content-wrapper">
    <section class="content">
       <div class="container-fluid">

            <div class="row mt-3">
                <div class="col-md-8">
                    <div class="form-group">
                        <label class="form-label fw-bold" style="font-size: 13px; color: #475569;">Buscar por</label>
                        <div class="input-group input-group-sm">
                            
                            <select class="form-select border-primary-subtle bg-light text-dark fw-medium" 
                                    style="max-width: 140px; font-size: 13px;" 
                                    @bind="tipoBusqueda">
                                <option value="cedula">Cédula/Doc</option>
                                <option value="placa">Placa</option>
                            </select>

                            <input type="text" 
                                   @bind="valorBusqueda" 
                                   class="form-control text-uppercase" 
                                   id="comparendoBusqueda" 
                                   placeholder="@(tipoBusqueda == "cedula" ? "Ingrese documento..." : "Ingrese placa...")" />
                            
                            <button @onclick="ConsultarVehiculos" class="btn btn-primary d-inline-flex align-items-center" type="button">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-search me-1" viewBox="0 0 16 16">
                                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" />
                                </svg>
                                Buscar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <hr />
            
            <div class="table-responsive border rounded" style="max-height: 350px; min-height: 150px;">
                <table class="table table-sm table-hover table-striped align-middle mb-0">
                    <thead class="sticky-top" style="background-color: #f1f5f9; z-index: 1;">
                        <tr>
                            <th style="font-size: 12px; color: #1e293b;">Placa</th>
                            <th style="font-size: 12px; color: #1e293b;">Clase Vehículo</th>
                            <th style="font-size: 12px; color: #1e293b;">Marca</th>
                            <th style="font-size: 12px; color: #1e293b;">Línea</th>
                            <th style="font-size: 12px; color: #1e293b;">Modelo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (vehiculosInfo == null || !vehiculosInfo.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4" style="font-size: 13px;">
                                    Ningún criterio cargado. Utilice el buscador superior.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var vehiculo in vehiculosInfo)
                            {
                                <tr @onclick="() => SeleccionarVehiculo(vehiculo)" 
                                    style="cursor: pointer; font-size: 13px;"
                                    class="@(selectedVehiculo != null && selectedVehiculo.Id == vehiculo.Id ? "table-primary fw-bold" : "")">
                                    <td><span class="badge bg-dark-subtle text-dark border font-monospace">@vehiculo.Placa</span></td>
                                    <td>@vehiculo.ClaseVehiculo</td> 
                                    <td>@vehiculo.Marca</td>         
                                    <td>@vehiculo.Linea</td>         
                                    <td>@vehiculo.Modelo</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <hr />
            
            <div class="d-flex align-items-center mb-3">
                @if (selectedVehiculo != null)
                {
                    <button type="button" class="btn btn-success btn-sm px-4 shadow-sm" 
                            style="border-radius: 15px; font-size: 12px;" 
                            @onclick="EnviarDatos">
                        <i class="bi bi-check2-circle"></i> Seleccionar Vehículo (@selectedVehiculo.Placa)
                    </button>
                }
            </div>

       </div>
    </section>
</div>

@code {
    private IEnumerable<PlacasByCedulaResponse> vehiculosInfo = Enumerable.Empty<PlacasByCedulaResponse>();
    private PlacasByCedulaResponse? selectedVehiculo; 
    
    // 🚀 Controles dinámicos de UI
    private string tipoBusqueda = "cedula"; 
    private string valorBusqueda = string.Empty;

    private void SeleccionarVehiculo(PlacasByCedulaResponse vehiculo)
    {
        selectedVehiculo = vehiculo;
    }

    private async Task ConsultarVehiculos()
    {
        if (string.IsNullOrWhiteSpace(valorBusqueda))
        {
            var msg = tipoBusqueda == "cedula" ? "Por favor ingrese un documento." : "Por favor ingrese una placa.";
            await JsRuntime.InvokeVoidAsync("alert", msg);
            return;
        }

        selectedVehiculo = null; 
        
        // 🚀 Inicializamos el Request limpio
        var request = new GetInfoVehiculoRequest();

        // Evaluamos qué propiedad llenar basándonos en la selección del componente
        if (tipoBusqueda == "cedula")
        {
            request.Cedula = valorBusqueda.Trim();
        }
        else
        {
            request.Placa = valorBusqueda.Trim().ToUpper();
        }

        var resultado = await VehiculosService.GetInfoVehiculo(request);
        
        if (resultado != null && resultado.Any())
        {
            vehiculosInfo = resultado;
        }
        else
        {
            vehiculosInfo = Enumerable.Empty<PlacasByCedulaResponse>();
            await JsRuntime.InvokeVoidAsync("alert", "No se encontraron vehículos registrados bajo este criterio.");
        }
    }

    private async Task EnviarDatos()
    {
        try
        {
            if (selectedVehiculo != null)
            {
                await BusquedaService.ComparendoCapturado(selectedVehiculo.Placa ?? "");
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al asignar el vehículo: {ex.Message}");
        }
    }
}