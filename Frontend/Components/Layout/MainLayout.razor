@inherits LayoutComponentBase
@using Domain.Models
@using Infrastructure.Services.Parametros
@inject IHttpContextAccessor Context
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ParametroService ParametroService;

<div class="app-layout-container">
    <div id="sidebarContainer" class="sidebar-wrapper">
        <NavMenu />
    </div>
    <div class="content-wrapper">
        <nav class="navbar navbar-expand shadow-sm px-4 py-0 sticky-top bg-white border-bottom border-light-subtle" 
             style="height: 70px;">
            <div class="container-fluid p-0">
                <div class="text-secondary m-0 fw-semibold" style="font-size: 0.9rem;">
                    <i class="bi bi-geo-alt me-2 text-warning fs-5"></i> @_parametro.Ciudad
                </div>

                <div class="d-flex align-items-center gap-4">
                    <div class="text-success small fw-medium d-flex align-items-center gap-2" style="font-size: 0.85rem;">
                        <span class="pulse-green"></span> Servidor Conectado
                    </div>

                    <div class="dropdown">
                        <a class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark fw-semibold"
                           href="#" role="button" id="userMenuToggle"
                           data-bs-toggle="dropdown" aria-expanded="false"
                           style="cursor:pointer; font-size: 0.85rem;">
                            <span class="me-1">@userName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm animated fadeIn"
                            aria-labelledby="userMenuToggle"
                            style="background-color: #ffffff; border: 1px solid rgba(0,0,0,.1); font-size: 0.85rem;">
                            <li><a class="dropdown-item py-2 text-secondary" href="/Usuariospage"><i class="bi bi-person me-2"></i> Mi Perfil</a></li>
                            <li><hr class="dropdown-divider border-light-subtle"></li>
                            <li><a class="dropdown-item py-2 text-danger" href="/PLogOut/CerrarSesion" target="_top"><i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <main class="p-4 flex-grow-1" style="background-color: #f8f9fa;">
            @Body
        </main>
    </div>
</div>

<style>
    /* Estructura Base */
    .app-layout-container {
        display: flex;
        min-height: 100vh;
        width: 100%;
        background-color: #f8f9fa;
    }

    /* Comportamiento del Sidebar Wrapper */
    .sidebar-wrapper {
        width: 260px; /* Ancho expandido por defecto */
        transition: width .25s cubic-bezier(0.4, 0, 0.2, 1);
        flex-shrink: 0;
        z-index: 1040;
    }

    /* CUANDO BOOTSTRAP LE AGREGUE LA CLASE .collapse, PASA A MEDIR 75PX (Modo íconos) */
    .sidebar-wrapper.collapse {
        width: 75px !important;
        display: block !important; /* Evita que Bootstrap lo oculte del todo */
    }

    /* Comportamiento del Contenido del Sistema */
    .content-wrapper {
        flex-grow: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        transition: all .25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Estilos Adicionales del Layout */
    .dropdown-item:hover { background-color: #f8f9fa !important; color: #112366 !important; }

    .pulse-green { width: 8px; height: 8px; background: #198754; border-radius: 50%; animation: pulse 2s infinite; }
    @@keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.4); } 70% { box-shadow: 0 0 0 8px rgba(25, 135, 84, 0); } 100% { box-shadow: 0 0 0 0 rgba(25, 135, 84, 0); } }

    .animated.fadeIn { animation: fadeIn 0.2s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    private Parametro _parametro = new Parametro { Ciudad = "Municipio" };
    private string userName = "Usuario";

    protected async override Task OnInitializedAsync()
    {
        // await GetClaimsPrincipalData();
        // _parametro = await ParametroService.GetParametroById(1);
    }

    private async Task GetClaimsPrincipalData()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true) userName = user.Identity.Name;
    }
}