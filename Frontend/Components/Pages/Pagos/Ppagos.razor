@page "/Pagos"
@using Domain.Models
@using Domain.Generics
@using Domain.Responses.Recibo
@using Domain.Responses.Recibo.Enums
@using Frontend.Reportes
@using Infrastructure.Services.Liquidaciones
@using Infrastructure.Services.Pagos
@using Infrastructure.Services.Parametros
@using Microsoft.AspNetCore.Components.Web

@inject LiquidacionService LiquiService
@inject IJSRuntime JsRuntime
@inject PagosService PagosServices
@inject ParametroService ParametroService
@inject NavigationManager NavigationManager
@inject HttpClient HttpClient
@rendermode InteractiveServer

<div class="py-2 px-4 text-white shadow-sm" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="d-flex align-items-center justify-content-between max-width-1400 mx-auto">
        <div class="d-flex align-items-center gap-3">
            <div class="p-2 rounded-3" style="background: rgba(255,255,255,0.2);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                    <rect x="2" y="5" width="20" height="14" rx="2"/>
                    <line x1="2" y1="10" x2="22" y2="10"/>
                </svg>
            </div>
            <h1 class="h5 mb-0 fw-light tracking-tight">Módulo de Pagos</h1>
        </div>
        <div class="px-3 py-1 rounded-pill" style="background: rgba(255,255,255,0.15); font-size: 0.8rem;">
            <span class="d-flex align-items-center gap-2">
                <span class="rounded-circle d-inline-block"
                      style="width: 8px; height: 8px; background-color: @(envia_ws ? "#10b981" : "#f59e0b");"></span>
                WS Estado
            </span>
        </div>
    </div>
</div>

<div class="container-fluid py-4" style="max-width: 1400px;">

    <div class="row align-items-end g-3 mb-4">
        <div class="col-12 col-md-4 col-lg-3">
            <label class="form-label text-uppercase text-muted fw-bold mb-1"
                   style="font-size: 0.7rem; letter-spacing: 0.05em;">Referencia de pago</label>
            <div class="input-group">
                <input type="number" class="form-control form-control-sm" @bind="reciboIdBusqueda"
                       placeholder="Número de recibo..."/>
                <button type="button" class="btn btn-dark btn-sm px-3" @onclick="BuscaRecibo">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                </button>
            </div>
        </div>

        @if (recibos != null && recibos.Id > 0)
        {
            <div class="col-12 col-md d-flex gap-4 justify-content-md-end mt-3 mt-md-0">
                <div>
                    <div class="text-muted" style="font-size: 0.7rem;">ESTADO</div>
                    <div class="d-flex align-items-center gap-2 mt-1">
                        <span class="rounded-circle d-inline-block"
                              style="width: 10px; height: 10px; background-color: @(recibos.Estado == EstadoRecibo.Aplicado ? "#10b981" : "#f59e0b");"></span>
                        <span class="fw-bold text-dark small">@recibos.Estado.GetDisplayName()</span>
                    </div>
                </div>
                <div class="border-start ps-4">
                    <div class="text-muted" style="font-size: 0.7rem;">TOTAL SISTEMA</div>
                    <div class="fw-bold text-dark h5 mb-0 mt-1">@recibos.ValorTotalSistema.ToString("C0")</div>
                </div>
            </div>
        }
    </div>

    @if (recibos != null && recibos.Id > 0 && recibos.Vehiculo != null)
    {
        <div class="card shadow-sm border-0 rounded-4 p-4 mb-4 bg-white">
            <div class="d-flex align-items-center gap-2 mb-4">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#667eea" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
                <span class="fw-bold text-secondary small">Línea de tiempo del pago</span>
            </div>

            <div class="d-flex align-items-center justify-content-between position-relative px-md-5">
                <div class="position-absolute w-75 start-50 translate-middle-x bg-light border-top border-2"
                     style="top: 20px; z-index: 0;"></div>

                <div class="text-center position-relative bg-white px-2" style="z-index: 1; width: 110px;">
                    <div
                        class="rounded-circle bg-white border border-2 border-primary mx-auto mb-2 d-flex align-items-center justify-content-center"
                        style="width: 40px; height: 40px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#667eea" stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                    </div>
                    <div class="text-muted fw-semibold" style="font-size: 0.75rem;">Creación</div>
                    <div class="text-primary fw-bold"
                         style="font-size: 0.7rem;">@recibos.Fecha.ToShortDateString()</div>
                </div>

                <div class="text-center position-relative bg-white px-2" style="z-index: 1; width: 110px;">
                    <div
                        class="rounded-circle bg-white border border-2 mx-auto mb-2 d-flex align-items-center justify-content-center @(recibos.FechaPago.HasValue ? "border-success" : "border-secondary-subtle")"
                        style="width: 40px; height: 40px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="@(recibos.FechaPago.HasValue ? "#10b981" : "#cbd5e1")" stroke-width="2">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    </div>
                    <div class="text-muted fw-semibold" style="font-size: 0.75rem;">Fecha pago</div>
                    <div class="fw-bold"
                         style="font-size: 0.7rem; color: @(recibos.FechaPago.HasValue ? "#10b981" : "#94a3b8");">
                        @(recibos.FechaPago.HasValue ? recibos.FechaPago.Value.ToShortDateString() : "Pendiente")
                    </div>
                </div>

                <div class="text-center position-relative bg-white px-2" style="z-index: 1; width: 110px;">
                    <div
                        class="rounded-circle bg-white border border-2 mx-auto mb-2 d-flex align-items-center justify-content-center @(recibos.FechaAplica.HasValue ? "border-primary" : "border-secondary-subtle")"
                        style="width: 40px; height: 40px;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="@(recibos.FechaAplica.HasValue ? "#667eea" : "#cbd5e1")" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    </div>
                    <div class="text-muted fw-semibold" style="font-size: 0.75rem;">Aplicación</div>
                    <div class="fw-bold"
                         style="font-size: 0.7rem; color: @(recibos.FechaAplica.HasValue ? "#667eea" : "#94a3b8");">
                        @(recibos.FechaAplica.HasValue ? recibos.FechaAplica.Value.ToShortDateString() : "Pendiente")
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 shadow-sm border-light-subtle p-3 rounded-3 bg-white">
                    <div class="text-muted text-uppercase fw-bold mb-2" style="font-size: 0.7rem;">Cobertura Cartera
                    </div>
                    <div class="fw-bold text-dark mb-2" style="font-size: 0.95rem;">Vigencias</div>
                    <div class="text-info fw-semibold mt-auto small">Desde @recibos.Desde hasta @recibos.Hasta</div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 shadow-sm border-light-subtle p-3 rounded-3 bg-white">
                    <div class="text-muted text-uppercase fw-bold mb-2" style="font-size: 0.7rem;">Desglose Económico
                    </div>
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="text-secondary">Capital:</span>
                        <span class="fw-semibold text-dark">@recibos.ValorCapital.ToString("C0")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="text-secondary">Interés Mora:</span>
                        <span class="fw-semibold text-danger">@recibos.InteresMora.ToString("C0")</span>
                    </div>
                    <div class="d-flex justify-content-between small mt-auto">
                        <span class="text-secondary">Descuentos:</span>
                        <span class="fw-semibold text-success">- @recibos.Descuento.ToString("C0")</span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 shadow-sm border-light-subtle p-3 rounded-3 bg-white">
                    <div class="text-muted text-uppercase fw-bold mb-2" style="font-size: 0.7rem;">Identificación
                        Vehículo
                    </div>
                    <div class="display-6 fw-bold text-dark tracking-wide mb-1"
                         style="font-size: 1.6rem;">@recibos.Vehiculo.Placa.ToUpper()</div>
                    <div class="text-muted small mt-auto">Generado: @recibos.Fecha.ToShortDateString()</div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 shadow-sm border-light-subtle p-3 rounded-3 bg-white">
                    <div class="text-muted text-uppercase fw-bold mb-2" style="font-size: 0.7rem;">Contribuyente
                        deudor
                    </div>
                    @if (recibos.Vehiculo.Propietario != null)
                    {
                        <div class="fw-bold text-dark text-truncate small" title="@recibos.Vehiculo.Propietario.Nombre">
                            @recibos.Vehiculo.Propietario.Nombre
                        </div>
                        <div class="text-muted small mt-2">
                            Doc: @recibos.Vehiculo.Propietario.Documento
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4 p-4 mb-4 bg-white">
            <div class="d-flex align-items-center gap-2 mb-3">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#667eea" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                </svg>
                <span class="fw-bold text-secondary small">Información técnica y destino del objeto vehicular</span>
            </div>

            <div class="row g-4">
                <div class="col-12 col-sm-6">
                    <div class="mb-3">
                        <div class="text-muted mb-1" style="font-size: 0.7rem;">Marca / Línea Mecánica</div>
                        <div
                            class="fw-semibold text-dark small">@(recibos.Vehiculo.Marca?.Nombre ?? "N/A") - @(recibos.Vehiculo.Linea?.Nombre ?? "N/A")</div>
                    </div>
                    <div>
                        <div class="text-muted mb-1" style="font-size: 0.7rem;">Total Liquidación (Lógica C#)</div>
                        <div class="h4 fw-bold text-indigo mb-0"
                             style="color: #4338ca;">@recibos.ValorTotalCalculado.ToString("C0")</div>
                    </div>
                </div>
                <div class="col-12 col-sm-6">
                    <div class="mb-3">
                        <div class="text-muted mb-1" style="font-size: 0.7rem;">Clase y Destinación del Servicio</div>
                        <div class="fw-semibold text-secondary small">
                            @recibos.Vehiculo.TipoServicioVehiculo.GetDisplayName()
                        </div>
                    </div>
                    <div>
                        <div class="text-muted mb-1" style="font-size: 0.7rem;">Cilindraje registrado</div>
                        <div class="fw-semibold text-dark small">@recibos.Vehiculo.Cilindraje cc</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="p-3 bg-light rounded-4 border border-light-subtle">
            <div class="row align-items-end g-3">
                <div class="col-12 col-lg">
                    <label class="form-label text-muted fw-bold mb-1" style="font-size: 0.75rem;">REGISTRO DE EVENTOS Y
                        AUDITORÍA</label>
                    <textarea @bind="mensaje" rows="3" class="form-control bg-white font-monospace small"
                              placeholder="// Historial operativo del recibo actual..."
                              style="font-size: 0.85rem;"></textarea>
                </div>
                <div class="col-12 col-lg-auto d-flex flex-wrap gap-2 justify-content-lg-end">
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm px-3 py-2 d-flex align-items-center gap-1"
                            @onclick="GenerarPdf">
                        <span>🖨️ PDF</span>
                    </button>

                    @if (recibos.Estado == EstadoRecibo.Pendiente)
                    {
                        <button type="button" class="btn btn-success btn-sm px-4 py-2 text-white fw-semibold"
                                @onclick="Procesar">
                            ✅ Procesar Pago
                        </button>
                    }

                    @if (recibos.Estado == EstadoRecibo.Aplicado)
                    {
                        <button type="button" class="btn btn-danger btn-sm px-4 py-2 fw-semibold" @onclick="Reversar">
                            ⚠️ Reversar Recibo
                        </button>
                    }
                </div>
            </div>
        </div>
    }
    else if (!isLoading && reciboIdBusqueda > 0)
    {
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
            <h5 class="text-muted fw-light mb-0">No se encontró información estructurada para el recibo ingresado.</h5>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
            <h5 class="text-muted fw-light mb-0">Ingresa un número de referencia para comenzar la operación</h5>
        </div>
    }
</div>

@if (mostrarSpinnerModal)
{
    <div class="modal-backdrop fade show" style="z-index: 1060;"></div>
    <div class="modal fade show d-block" tabindex="-1" style="z-index: 1070;">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
            <div class="modal-content shadow border-0 py-3">
                <div class="modal-body text-center">
                    <div class="spinner-border text-primary mb-3" role="status"
                         style="width: 3rem; height: 3rem;"></div>
                    <h6 class="text-dark fw-bold mb-1">Generando PDF Oficial</h6>
                    <p class="text-muted small mb-0">Compilando liquidaciones de recaudo, por favor espere...</p>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int reciboIdBusqueda;
    public Recibo recibos { get; set; } = new();
    public List<DetalleReciboDto> Listxconc = [];
    private Parametro param_obj = new();

    private bool isLoading = false;
    public bool envia_ws = false;
    public string mensaje = "";
    private bool mostrarSpinnerModal = false; // Control de visualización para el Loading del PDF

    protected async override Task OnInitializedAsync()
    {
        param_obj = await ParametroService.GetParametroById(1) ?? new Parametro();
    }

    private async Task BuscaRecibo()
    {
        try
        {
            if (reciboIdBusqueda == 0)
            {
                await JsRuntime.InvokeVoidAsync("alert", "Por favor, ingresa un valor de Recibo numérico.");

                return;
            }

            isLoading = true;
            var result = await PagosServices.GetRecibo(reciboIdBusqueda);

            if (result != null)
            {
                recibos = result;
                mensaje = $"// Recibo {recibos.Id} cargado exitosamente el {DateTime.UtcNow}. Estado actual: {recibos.Estado.GetDisplayName()}";
            }
            else
            {
                recibos = new Recibo();
                await JsRuntime.InvokeVoidAsync("alert", "El recibo ingresado no existe en el sistema.");
            }
        }
        catch (Exception ex)
        {
            mensaje = $"// Error en la carga del recibo: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Procesar()
    {
        if (recibos.Id <= 0 || recibos.Estado != EstadoRecibo.Pendiente)
        {
            await JsRuntime.InvokeVoidAsync("alert", "El recibo no se encuentra en estado PENDIENTE para procesar.");

            return;
        }

        bool confirmar = await JsRuntime.InvokeAsync<bool>("confirm", "¿Está seguro de aplicar este pago al sistema vehicular?");
        if (confirmar)
        {
            try
            {
                await PagosServices.Procesa_Rec(recibos.Id, recibos.Vehiculo.Placa);
                await JsRuntime.InvokeVoidAsync("alert", "El pago ha sido asentado y la cartera descargada con éxito.");
                await BuscaRecibo();
            }
            catch (Exception ex)
            {
                await JsRuntime.InvokeVoidAsync("alert", $"Error interno al procesar el pago: {ex.Message}");
            }
        }
    }

    private async Task Reversar()
    {
        if (recibos.Id <= 0 || recibos.Estado != EstadoRecibo.Aplicado)
        {
            await JsRuntime.InvokeVoidAsync("alert", "Únicamente los recibos APLICADOS / PAGADOS se pueden reversar.");

            return;
        }

        bool confirmar = await JsRuntime.InvokeAsync<bool>("confirm", "¿Está seguro de reversar el dinero? Se reactivará la deuda en mora.");
        if (confirmar)
        {
            try
            {
                await PagosServices.Reversa_Rec(recibos.Id);
                await JsRuntime.InvokeVoidAsync("alert", "Transacción reversada. La cartera del vehículo vuelve a estar activa.");
                await BuscaRecibo();
            }
            catch (Exception ex)
            {
                await JsRuntime.InvokeVoidAsync("alert", $"Error al ejecutar el reverso: {ex.Message}");
            }
        }
    }

    private async Task GenerarPdf()
    {
        if (recibos.Id <= 0) return;

        mostrarSpinnerModal = true;
        StateHasChanged();

        try
        {
            var response = await LiquiService.Items_x_Recibo(recibos.Id);
            if (response != null && response.Any())
            {
                Listxconc = response.Select(x => new DetalleReciboDto
                {
                    Vigencia = x.Vigencia,
                    ValorRodamiento = x.ValorRodamiento,
                    ValorCarga = x.ValorCarga,
                    ValorEstampillas = x.ValorEstampillas,
                    ValorRecibo = x.ValorRecibo,
                    ValorInteres = x.ValorInteres
                }).ToList();
            }
            else
            {
                Listxconc = [];
            }

            var reporte = new Recibo_pago();
            await reporte.CreatePdf(recibos, Listxconc, param_obj);

            await Task.Delay(1000); // Mantenemos el retraso controlado para asegurar la escritura en el disco local
            string reciboPdf = $"Recibo_{recibos.Id}.pdf";
            await DescargarYAbrirArchivo(reciboPdf.Trim());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error crítico generando documento oficial: {ex.Message}");
        }
        finally
        {
            mostrarSpinnerModal = false;
            StateHasChanged();
        }
    }

    private async Task DescargarYAbrirArchivo(string fileName)
    {
        try
        {
            string fileUrl = $"{NavigationManager.BaseUri}api/archivos/{fileName}";
            HttpResponseMessage response = await HttpClient.GetAsync(fileUrl);
            if (response.IsSuccessStatusCode)
            {
                var fileBytes = await response.Content.ReadAsByteArrayAsync();
                var contentStream = new DotNetStreamReference(new MemoryStream(fileBytes));
                await JsRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, contentStream);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al despachar el archivo al navegador: {ex.Message}");
        }
    }

}