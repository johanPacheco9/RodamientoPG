@page "/Marcas"
@using Infrastructure.Services.Marcas
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@inject MarcaService AgentesServices
@inject IJSRuntime JsRuntime

<div class="container-fluid px-4 py-3">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3" style="border-left: 4px solid #112366;">
            <div class="row align-items-center g-3">
                <div class="col-md-4 col-sm-12">
                    <h5 class="mb-0 fw-bold text-dark text-uppercase tracking-wider" style="font-size: 16px;">
                        <i class="bi bi-tags-fill me-2" style="color: #112366;"></i>Marcas de Vehículos
                    </h5>
                    <small class="text-muted">Configuración de catálogos y grupos maestros del sistema</small>
                </div>
                <div class="col-md-5 col-sm-8">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                 class="bi bi-search" viewBox="0 0 16 16">
                                <path
                                    d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                            </svg>
                        </span>
                        <input type="text" class="form-control bg-light border-start-0 ps-1"
                               @bind="_buscarnit" placeholder="Buscar marca por nombre..." style="font-size: 14px;"/>
                        <button type="button" @onclick="findbyplaca" class="btn text-white px-4"
                                style="background-color: #112366; font-size: 13px;">
                            Buscar
                        </button>
                    </div>
                </div>
                <div class="col-md-3 col-sm-4 text-end">
                    <button type="button" class="btn btn-success d-inline-flex align-items-center gap-2 px-3 shadow-sm"
                            @onclick=@(args => MostrarModal(false)) style="font-size: 13px; font-weight: 500;">
                        <i class="bi bi-plus-lg"></i> Crear Marca
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_alertaMensaje))
    {
        <div class="alert alert-@_alertaTipo alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @_alertaMensaje
            <button type="button" class="btn-close" @onclick="LimpiarAlerta"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (_isLoading)
            {
                <div class="d-flex flex-column align-items-center justify-content-center p-5 my-4">
                    <div class="spinner-border text-primary mb-3" role="status"
                         style="width: 2.5rem; height: 2.5rem; color: #112366 !important;"></div>
                    <span class="text-muted fw-medium">Cargando catálogos...</span>
                </div>
            }
            else if (_marcaList == null || !_marcaList.Any()) // 🚀 CORREGIDO: Evaluamos la lista real de registros
            {
                <div class="text-center p-5 my-4">
                    <i class="bi bi-folder-x text-muted display-4"></i>
                    <p class="mt-3 text-secondary fw-semibold mb-0">No se encontraron marcas configuradas.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle mb-0" style="font-size: 13px;">
                        <thead class="table-light text-secondary uppercase border-bottom"
                               style="font-size: 11px; font-weight: 700; background-color: #f8f9fa;">
                        <tr>
                            <th scope="col" class="ps-4 py-3 text-dark" style="width: 100px;">ID</th>
                            <th scope="col" class="py-3 text-dark">NOMBRE GRUPO / MARCA</th>
                            <th scope="col" class="pe-4 py-3 text-end text-dark" style="width: 150px;">ACCIONES</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in _marcaList)
                        {
                            <tr @onclick="() => OnRowSelect(item)" class="cursor-pointer">
                                <td class="ps-4 fw-semibold text-secondary">#@item.Id</td>
                                <td class="fw-bold text-dark text-uppercase">@item.Nombre</td>
                                <td class="pe-4 text-end">
                                    <button
                                        class="btn btn-sm btn-outline-secondary btn-icon-only rounded-circle border-0 me-1"
                                        @onclick="() => EditarAgentes(item)" @onclick:stopPropagation="true"
                                        title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger btn-icon-only rounded-circle border-0"
                                            @onclick="() => EliminaAgentes(item.Id)" @onclick:stopPropagation="true"
                                            title="Eliminar">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                <div class="card-footer bg-white border-top p-3 d-flex align-items-center justify-content-between">
                    <small class="text-muted fw-medium">Mostrando registros de marcas indexadas</small>
                    <div class="btn-group btn-group-sm shadow-xs" role="group">
                        <button type="button" class="btn btn-outline-secondary px-3" disabled>Anterior</button>
                        <button type="button" class="btn btn-outline-secondary px-3 active">1</button>
                        <button type="button" class="btn btn-outline-secondary px-3" disabled>Siguiente</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (_mostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background: rgba(15, 23, 42, 0.5); backdrop-filter: blur(4px); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 550px;">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header text-white border-0 py-3"
                     style="background: linear-gradient(135deg, #112366, #1d3557);">
                    <h5 class="modal-title fw-bold fs-6 d-flex align-items-center gap-2">
                        <i class="bi @(_esModoEditar ? "bi-pencil-square" : "bi-plus-circle")"></i>
                        @(_esModoEditar ? "Modificar Nombre de Marca" : "Agregar Nueva Marca de Vehículo")
                    </h5>
                    <button type="button" class="btn-close btn-close-white shadow-none" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body bg-light p-4">
                    @if (_marca != null)
                    {
                        <div class="card card-body border-0 shadow-xs p-3">
                            <div class="row g-3 align-items-center">
                                <div class="col-sm-3">
                                    <label class="form-label text-secondary small fw-medium mb-1">Id Catálogo</label>
                                    <input type="text"
                                           class="form-control form-control-sm text-center bg-body-secondary fw-bold"
                                           @bind="_marca.Id" readonly/>
                                </div>
                                <div class="col-sm-9">
                                    <label class="form-label text-secondary small fw-medium mb-1">Nombre Oficial de la
                                        Marca</label>
                                    <input type="text" maxlength="40"
                                           class="form-control form-control-sm border-secondary-subtle fw-bold text-uppercase"
                                           @bind="_marca.Nombre" placeholder="Ej. CHEVROLET, MAZDA..."/>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer border-top p-3 bg-white d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary px-3" @onclick="CerrarModal">
                        <i class="bi bi-x-circle"></i> Cerrar
                    </button>
                    <button type="button" class="btn btn-sm text-white px-4 shadow-sm"
                            style="background-color: #112366;"
                            @onclick="() => _esModoEditar ? Actualizar(_marca) : Agregar()">
                        <i class="bi bi-cloud-arrow-up-fill me-1"></i> @(_esModoEditar ? "Actualizar" : "Guardar Registro")
                    </button>
                </div>
            </div>
        </div>
    </div>
}
