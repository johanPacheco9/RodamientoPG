@page "/Principal"
@using Domain.Generics
@rendermode InteractiveServer

<PageTitle>Dashboard</PageTitle>

<div class="container-fluid p-4">

    <div class="mb-4">
        <h5 class="fw-medium mb-0">Dashboard</h5>
        <small class="text-muted">Distribución de vehículos registrados por clase y tipo de servicio</small>
    </div>

    @if (!Itemlist.Any())
    {
        <div class="card">
            <div class="card-body text-center py-5 text-muted">
                <i class="bi bi-bar-chart fs-1 d-block mb-2 opacity-50"></i>
                <p class="mb-0">No hay datos para mostrar.</p>
            </div>
        </div>
    }
    else
    {
        <!-- Métricas -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card h-100">
                    <div class="card-body py-2 px-3">
                        <small class="text-muted d-block">Total vehículos</small>
                        <span class="fw-medium fs-5">@TotalVehiculos.ToString("N0")</span>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card h-100">
                    <div class="card-body py-2 px-3">
                        <small class="text-muted d-block">Clases distintas</small>
                        <span class="fw-medium fs-5">@ClasesDistintas</span>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card h-100">
                    <div class="card-body py-2 px-3">
                        <small class="text-muted d-block">Tipos de servicio</small>
                        <span class="fw-medium fs-5">@TiposServicio</span>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card h-100">
                    <div class="card-body py-2 px-3">
                        <small class="text-muted d-block">Clase más común</small>
                        <span class="fw-medium fs-5">@ClaseMasComun</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header py-2 px-3 d-flex align-items-center justify-content-between" style="background-color: #f8f9fa;">
                <span class="fw-medium text-dark" style="font-size:13px;">
                    <i class="bi bi-pie-chart-fill me-1 text-primary"></i> Participación de Vehículos por Clase
                </span>
                <span class="badge bg-secondary" style="font-size:11px;">
                    @TotalVehiculos.ToString("N0") registros
                </span>
            </div>
            <div class="card-body p-3">
                <div style="position:relative; height:280px; max-width: 550px; margin: 0 auto;">
                    <canvas id="vehiculosChart"></canvas>
                </div>
            </div>
        </div>
        <!-- Tabla -->
        <div class="card">
            <div class="card-header py-2 px-3">
                <span class="fw-medium" style="font-size:13px;">Detalle por clase y servicio</span>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Clase</th>
                            <th>Tipo servicio</th>
                            <th class="text-end">Cantidad</th>
                            <th class="text-end">% del total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Itemlist.OrderByDescending(x => x.CantidadVehiculos))
                        {
                            var pct = TotalVehiculos > 0
                                ? (double)item.CantidadVehiculos / TotalVehiculos * 100
                                : 0;
                            <tr>
                                <td><strong>@item.TipoVehiculo</strong></td>
                                <td>@item.TipoServicio.GetDisplayName()</td>
                                <td class="text-end">@item.CantidadVehiculos.ToString("N0")</td>
                                <td class="text-end">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        <div style="width:70px; height:6px; background:#f1f1f1; border-radius:3px; overflow:hidden;">
                                            <div style="width:@(pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%; height:100%; background:#185FA5; border-radius:3px;"></div>
                                        </div>
                                        <span style="min-width:38px;">@(pct.ToString("F1"))%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="2" class="text-end fw-medium text-muted small">Total:</td>
                            <td class="text-end fw-medium">@TotalVehiculos.ToString("N0")</td>
                            <td class="text-end fw-medium">100%</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
</div>
<script>
    window._charts = {};

    window.renderChart = (id, config) => {
        if (window._charts[id]) {
            window._charts[id].destroy();
        }
        const ctx = document.getElementById(id);
        if (!ctx) return;
        window._charts[id] = new Chart(ctx, config);
    };
</script>