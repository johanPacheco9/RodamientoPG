@page "/Consulta"
@page "/Consulta/{PlacaParam}"
@using Domain.Generics
@using Domain.Models
@using Domain.Models.ProcesoLiquidacion
@using Domain.Responses.Liquidacion
@using Domain.Responses.Recibo
@using Infrastructure.Services.Importados
@using Infrastructure.Services.Liquidaciones
@using Infrastructure.Services.Pagos
@using Infrastructure.Services.Parametros
@using Infrastructure.Services.Procesos.Coactivo
@using Infrastructure.Services.Procesos.Persuasivo
@using Infrastructure.Services.Vehiculos
@rendermode InteractiveServer

<!-- ─── Encabezado de página ─────────────────────────────────── -->
<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h5 class="mb-0 fw-medium">Estado de cuenta vehicular</h5>
        <small class="text-muted">Consulta de deuda, recibos y procesos activos</small>
    </div>
    <button class="btn btn-primary btn-sm" @onclick="ShowBusqueda">
        <i class="bi bi-person-vcard"></i> Buscar por documento
    </button>
</div>

<!-- ─── Card: Propietario + Vehículo ─────────────────────────── -->
@if (!string.IsNullOrEmpty(_estadoCuenta?.Documento))
{
    <div class="card mb-3">
        <div class="card-body py-3">

            <p class="text-muted mb-2"
               style="font-size:11px; font-weight:500; text-transform:uppercase; letter-spacing:.04em;">
                <i class="bi bi-person"></i> Propietario
            </p>
            <div class="d-flex align-items-center gap-3 mb-3">
                <div
                    class="rounded-circle bg-primary bg-opacity-10 text-primary fw-medium d-flex align-items-center justify-content-center"
                    style="width:40px; height:40px; font-size:14px; flex-shrink:0;">
                    @Iniciales(_estadoCuenta.NombrePropietario)
                </div>
                <div>
                    <div class="fw-medium">@_estadoCuenta.NombrePropietario</div>
                    <small class="text-muted">@_estadoCuenta.TipoDocumento · @_estadoCuenta.Documento</small>
                </div>
                <div class="ms-auto">
                    <span class="badge @BadgeEstado(_estadoCuenta.EstadoId)">
                        @_estadoCuenta.EstadoNombre
                    </span>
                </div>
            </div>

            <hr class="my-2">

            <p class="text-muted mb-2"
               style="font-size:11px; font-weight:500; text-transform:uppercase; letter-spacing:.04em;">
                <i class="bi bi-car-front"></i> Vehículo · <strong>@_estadoCuenta.Placa</strong>
            </p>
            <div class="row g-2">
                <div class="col-6 col-md-2">
                    <small class="text-muted d-block">Marca</small>
                    <span class="fw-medium small">@_estadoCuenta.Marca</span>
                </div>
                <div class="col-6 col-md-2">
                    <small class="text-muted d-block">Línea</small>
                    <span class="fw-medium small">@_estadoCuenta.Linea</span>
                </div>
                <div class="col-6 col-md-2">
                    <small class="text-muted d-block">Modelo</small>
                    <span class="fw-medium small">@_estadoCuenta.Modelo</span>
                </div>
                <div class="col-6 col-md-2">
                    <small class="text-muted d-block">Clase</small>
                    <span class="fw-medium small">@_estadoCuenta.Clase</span>
                </div>
                <div class="col-6 col-md-2">
                    <small class="text-muted d-block">Tipo servicio</small>
                    <span class="fw-medium small">@_estadoCuenta.TipoServicio</span>
                </div>
                <div class="col-6 col-md-2">
                    <small class="text-muted d-block">Cilindraje</small>
                    <span class="fw-medium small">@_estadoCuenta.Cilindraje</span>
                </div>
                <div class="col-6 col-md-2">
                    <small class="text-muted d-block">Color</small>
                    <span class="fw-medium small">@_estadoCuenta.Color</span>
                </div>
                <div class="col-6 col-md-2">
                    <small class="text-muted d-block">Carrocería</small>
                    <span class="fw-medium small">@_estadoCuenta.Carroceria</span>
                </div>
                <div class="col-6 col-md-2">
                    <small class="text-muted d-block">Vigencia desde</small>
                    <span class="fw-medium small">@_estadoCuenta.VigenciaDesde</span>
                </div>
                <div class="col-6 col-md-2">
                    <small class="text-muted d-block">Vigencia hasta</small>
                    <span class="fw-medium small">@_estadoCuenta.VigenciaHasta</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body py-2 px-3">
                    <small class="text-muted d-block">Total deuda</small>
                    <span class="fw-medium text-danger fs-5">@_estadoCuenta.TotalDeuda.ToString("C")</span>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body py-2 px-3">
                    <small class="text-muted d-block">Vigencias pendientes</small>
                    <span class="fw-medium fs-5">@_vigencias.Count año(s)</span>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body py-2 px-3">
                    <small class="text-muted d-block">Último pago</small>
                    <span
                        class="fw-medium fs-5">@(_estadoCuenta.UltimoPago.HasValue ? _estadoCuenta.UltimoPago.Value.ToString("MMM yyyy") : "—")</span>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body py-2 px-3">
                    <small class="text-muted d-block">Proceso activo</small>
                    @if (coactivosList.Any(p => p.EstadoProceso.GetDisplayName().ToLower() == "coactivo"))
                    {
                        <span class="badge bg-danger">Coactivo</span>
                    }
                    else if (coactivosList.Any(p => p.EstadoProceso.GetDisplayName().ToLower() == "persuasivo"))
                    {
                        <span class="badge bg-warning text-dark">Persuasivo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Ninguno</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header p-0">
            <ul class="nav nav-tabs card-header-tabs px-3">
                <li class="nav-item">
                    <button class="nav-link @(tab == 1 ? "active" : "")" @onclick="() => SetTab(1)">
                        <i class="bi bi-receipt"></i> Estado de cuenta
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(tab == 2 ? "active" : "")" @onclick="() => SetTab(2)">
                        <i class="bi bi-file-earmark-text"></i> Recibos
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(tab == 3 ? "active" : "")" @onclick="() => SetTab(3)">
                        <i class="bi bi-bar-chart"></i> Resumen conceptos
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(tab == 4 ? "active" : "")" @onclick="() => SetTab(4)">
                        <i class="bi bi-journal-text"></i> Resoluciones
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(tab == 5 ? "active" : "")" @onclick="() => SetTab(5)">
                        <i class="bi bi-gavel"></i> Procesos
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body p-3">

            @if (tab == 1)
            {
                <p class="text-muted mb-2"
                   style="font-size:11px; text-transform:uppercase; letter-spacing:.04em; font-weight:500;">
                    Seleccione las vigencias a pagar
                </p>
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                        <tr>
                            <th style="width:44px;" class="text-center">Pagar</th>
                            <th>Vigencia</th>
                            <th>Conceptos</th>
                            <th class="text-end">Impuesto</th>
                            <th class="text-end">Interés mora</th>
                            <th class="text-end">Descuento</th>
                            <th class="text-end">Total vigencia</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var grupo in _vigencias)
                        {
                            <tr class="@(grupo.Seleccionado ? "table-primary" : "") fw-medium">
                                <td class="text-center">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           @bind="grupo.Seleccionado"
                                           @bind:after="RecalcularTotal"/>
                                </td>
                                <td><strong>@grupo.Vigencia</strong></td>
                                <td>
                                    @foreach (var c in grupo.Conceptos)
                                    {
                                        <span class="badge bg-secondary me-1">@c.Concepto</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @grupo.Conceptos.Sum(c => c.Valor).ToString("C")
                                </td>
                                <td class="text-end">
                                    @grupo.Conceptos.Sum(c => c.ValorInteres).ToString("C")
                                </td>
                                <td class="text-end">
                                    @if (grupo.Conceptos.Sum(c => c.Descuento) > 0)
                                    {
                                        <span class="badge bg-success-subtle text-success-emphasis">
                                            -@grupo.Conceptos.Sum(c => c.Descuento).ToString("C")
                                        </span>
                                    }
                                    else
                                    {
                                        <span>$0</span>
                                    }
                                </td>
                                <td class="text-end fw-medium">@grupo.TotalVigencia.ToString("C")</td>
                            </tr>
                        }
                        </tbody>
                        <tfoot class="table-light">
                        <tr>
                            <td colspan="6" class="text-end text-muted small">
                                Total seleccionado (@carterasSeleccionadasIds.Count concepto(s)):
                            </td>
                            <td class="text-end fw-medium text-danger">@totalSeleccionado.ToString("C")</td>
                        </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="d-flex align-items-center justify-content-between mt-2 gap-2 flex-wrap
                            bg-light rounded p-2">
                    <div class="d-flex gap-2 flex-wrap">
                        <button class="btn btn-primary btn-sm" @onclick="GenerarRecibo"
                                disabled="@(!carterasSeleccionadasIds.Any())">
                            <i class="bi bi-printer"></i> Generar recibo
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="GenerarPazYSalvo">
                            <i class="bi bi-file-earmark-check"></i> Paz y salvo
                        </button>
                    </div>
                    <div class="text-end">
                        <small class="text-muted d-block">Total a pagar</small>
                        <span class="fw-medium text-danger fs-5">@totalSeleccionado.ToString("C")</span>
                    </div>
                </div>
            }

            @if (tab == 2)
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                        <tr>
                            <th>No. recibo</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th>Fecha pago</th>
                            <th>Rango vigencias</th>
                            <th class="text-end">Capital</th>
                            <th class="text-end">Interés</th>
                            <th class="text-end">Descuento</th>
                            <th class="text-end">Total</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var r in reciboslist)
                        {
                            <tr>
                                <td><strong>#@r.Id</strong></td>
                                <td>@r.Fecha.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge @BadgeRecibo(r.Estado.GetDisplayName())">@r.Estado</span></td>
                                <td>@(r.FechaPago?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>@r.Desde – @r.Hasta</td>
                                <td class="text-end">@r.ValorCapital.ToString("C")</td>
                                <td class="text-end">@r.InteresMora.ToString("C")</td>
                                <td class="text-end">@r.Descuento.ToString("C")</td>
                                <td class="text-end fw-medium">@r.ValorTotalCalculado.ToString("C")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }

            @if (tab == 3)
            {
                <div class="mb-3">
                    <h6 class="fw-semibold text-secondary mb-1">Desglose detallado por vigencia y concepto</h6>
                    <p class="text-muted small">A continuación se detalla el comportamiento financiero de cada rubro
                        parametrizado discriminado por su año fiscal correspondiente.</p>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle" style="font-size: 13px;">
                        <thead class="table-light border-bottom">
                        <tr>
                            <th style="width: 12%;">Vigencia</th>
                            <th>Concepto / Rubro</th>
                            <th class="text-end" style="width: 16%;">Capital Base</th>
                            <th class="text-end" style="width: 16%;">Interés Mora</th>
                            <th class="text-end" style="width: 16%;">Descuento</th>
                            <th class="text-end" style="width: 18%;">Total Rubro</th>
                        </tr>
                        </thead>
                        <tbody>

                        @foreach (var rubroDetallado in _vigencias
                                      .SelectMany(v => v.Conceptos.Select(c => new { v.Vigencia, Detalle = c }))
                                      .OrderBy(r => r.Vigencia)
                                      .ThenBy(r => r.Detalle.Concepto))
                        {
                            var totalItem = rubroDetallado.Detalle.Valor + rubroDetallado.Detalle.ValorInteres - rubroDetallado.Detalle.Descuento;

                            <tr>
                                <td>
                        <span
                            class="badge bg-light text-dark border border-secondary border-opacity-25 font-monospace px-2 py-1 fw-bold">
                            @rubroDetallado.Vigencia
                        </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-arrow-right-short text-primary"></i>
                                        <span class="fw-medium text-dark text-uppercase" style="font-size: 12.5px;">
                                @rubroDetallado.Detalle.Concepto
                            </span>
                                    </div>
                                </td>
                                <td class="text-end font-monospace text-secondary">
                                    @rubroDetallado.Detalle.Valor.ToString("C0")
                                </td>
                                <td class="text-end font-monospace text-danger">
                                    @rubroDetallado.Detalle.ValorInteres.ToString("C0")
                                </td>
                                <td class="text-end font-monospace text-success">
                                    @if (rubroDetallado.Detalle.Descuento > 0)
                                    {
                                        <span>-@rubroDetallado.Detalle.Descuento.ToString("C0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted opacity-50">$0</span>
                                    }
                                </td>
                                <td class="text-end font-monospace fw-bold text-dark bg-light bg-opacity-25">
                                    @totalItem.ToString("C0")
                                </td>
                            </tr>
                        }
                        </tbody>
                        <tfoot class="table-light fw-bold border-top-2 text-dark">
                        <tr>
                            <td colspan="2" class="text-end fw-medium text-muted">Total General Consolidado:</td>
                            <td class="text-end font-monospace text-secondary">
                                @_vigencias.SelectMany(v => v.Conceptos).Sum(c => c.Valor).ToString("C0")
                            </td>
                            <td class="text-end font-monospace text-danger">
                                @_vigencias.SelectMany(v => v.Conceptos).Sum(c => c.ValorInteres).ToString("C0")
                            </td>
                            <td class="text-end font-monospace text-success">
                                @_vigencias.SelectMany(v => v.Conceptos).Sum(c => c.Descuento).ToString("C0")
                            </td>
                            <td class="text-end font-monospace text-danger fs-6 bg-danger bg-opacity-10 fw-bold">
                                @_estadoCuenta.TotalDeuda.ToString("C0")
                            </td>
                        </tr>
                        </tfoot>
                    </table>
                </div>
            }

            @if (tab == 4)
            {
                <div class="d-flex justify-content-end mb-2">
                    <button class="btn btn-warning btn-sm" @onclick="MostrarModal_R">
                        <i class="bi bi-plus"></i> Crear resolución
                    </button>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                        <tr>
                            <th>Id</th>
                            <th>Fecha</th>
                            <th>No. resolución</th>
                            <th>Tipo</th>
                            <th>Vigencias Afectadas</th>
                            <th>Observaciones</th>
                            <th>Estado</th>
                            <th class="text-end">Valor</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var r in resolucioneslist)
                        {
                            <tr>
                                <td>@r.Id</td>
                                <td>@r.Fecha.ToString("dd/MM/yyyy")</td>
                                <td><strong>@r.NumeroResolucion</strong></td>
                                <td>
                        <span class="badge bg-info-subtle text-info-emphasis">
                            @r.TipoResolucion.GetDisplayName()
                        </span>
                                </td>
                                <td>
                                    @if (r.AnioDesde.HasValue)
                                    {
                                        @if (r.AnioDesde == r.AnioHasta)
                                        {
                                            <span>@r.AnioDesde</span>
                                        }
                                        else
                                        {
                                            <span>@r.AnioDesde – @r.AnioHasta</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic small">Sin vigencias</span>
                                    }
                                </td>
                                <td class="text-muted small">@r.Observaciones</td>
                                <td><span class="badge @BadgeEstadoProceso(r.Estado)">@r.Estado</span></td>
                                <td class="text-end">@r.Valor.ToString("C")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }

            @if (tab == 5)
            {
                <div class="d-flex justify-content-end mb-2">
                    <button class="btn btn-success btn-sm" @onclick="MostrarModal">
                        <i class="bi bi-plus"></i> Iniciar cobro persuasivo
                    </button>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                        <tr>
                            <th>Id</th>
                            <th>Fecha</th>
                            <th>No. proceso</th>
                            <th>Tipo</th>
                            <th>Resolución</th>
                            <th>Período</th>
                            <th>Estado</th>
                            <th class="text-center">Avisos</th>
                            <th class="text-end">Valor</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var p in coactivosList)
                        {
                            <tr>
                                <td>@p.Id</td>
                                <td>@p.Fecha.ToString("dd/MM/yyyy")</td>
                                <td><strong>@p.NumeroProceso</strong></td>
                                <td>
                                    <span class="badge @BadgeProceso(p.EstadoProceso.GetDisplayName())">
                                        @p.EstadoProceso.GetDisplayName()
                                    </span>
                                </td>
                                <td>@p.Resolucion</td>
                                <td>@p.Desde – @p.Hasta</td>
                                <td>
                                            <span class="badge @BadgeEstadoProceso(p.EstadoProceso)">
                                                @p.EstadoProceso.GetDisplayName()
                                            </span>
                                </td>
                                <td class="text-center">
                                            <span
                                                class="badge @(AvisosProceso(p) >= 4 ? "bg-success" : "bg-secondary")">
                                                @AvisosProceso(p)/4
                                            </span>
                                </td>
                                <td class="text-end">@p.Valor.ToString("C")</td>
                                <td class="text-end">
                                    @if (p.EstadoProceso == EstadoProceso.Persuasivo)
                                    {
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary"
                                                    @onclick="() => RegistrarAviso(p)"
                                                    disabled="@(AvisosProceso(p) >= 4)">
                                                Aviso
                                            </button>
                                            <button class="btn btn-outline-danger"
                                                    @onclick="() => PasarACoactivo(p)"
                                                    disabled="@(AvisosProceso(p) < 4)">
                                                Coactivo
                                            </button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
}
<!-- ─── Modal: Búsqueda por cédula ───────────────────────────── -->
@if (MostrarBusquedaCedula)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-person-vcard"></i> Buscar vehículo por documento
                    </h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body" style="min-height: 400px;">
                    @if (MostrarBusquedaCedula)
                    {
                        <Busqueda/>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- ─── Modal: Iniciar persuasivo / deuda ────────────────────── -->
@if (_mostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Iniciar cobro persuasivo</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">Vigencia desde</label>
                            <input class="form-control" type="number" @bind="vigenciaDesde"/>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Vigencia hasta</label>
                            <input class="form-control" type="number" @bind="vigenciaHasta"/>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn btn-success btn-sm" @onclick="Agregar">
                        <i class="bi bi-check"></i> Confirmar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ─── Modal: Crear resolución ──────────────────────────────── -->
@if (_mostrarModalr)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Crear resolución de rodamiento</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Tipo de Resolución</label>
                            <select class="form-select" @onchange="capturar">
                                <option value="1">Traslado de Cuenta</option>
                                <option value="2">Anulación de Deuda</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Fecha de Expedición</label>
                            <input class="form-control" type="date" @bind="resolObj.Fecha"/>
                        </div>

                        @if (_vigencias == null || !_vigencias.Any())
                        {
                            <div class="alert alert-info py-2">No hay vigencias pendientes cargadas para este
                                vehículo.
                            </div>
                        }
                        else
                        {
                            <div class="card p-3" style="max-height: 200px; overflow-y: auto;">
                                <div class="row">
                                    @foreach (var v in _vigencias)
                                    {
                                        <div class="col-6 col-sm-4 mb-2">
                                            <div class="form-check">
                                                <!-- Usamos una propiedad temporal para no alterar la selección de la grilla principal si no quieres -->
                                                <input class="form-check-input" type="checkbox" id="chk-@v.Vigencia"
                                                       @bind="v.Seleccionado"/>
                                                <label class="form-check-label" for="chk-@v.Vigencia">
                                                    <strong>@v.Vigencia</strong>
                                                    <span
                                                        class="text-muted small">($@v.TotalVigencia.ToString("N0"))</span>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- 🚀 El valor monetario ya no se digita, se totaliza sumando las deudas del rango en el backend -->

                        <div class="col-12">
                            <label class="form-label">Observaciones / Sustento Legal</label>
                            <textarea class="form-control" rows="3"
                                      placeholder="Escriba los motivos o el número de radicado externo..."
                                      @bind="resolObj.Observaciones"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn btn-warning btn-sm" @onclick="Agregar_resol">
                        <i class="bi bi-file-earmark-check"></i> Generar resolución consecutiva
                    </button>
                </div>
            </div>
        </div>
    </div>
}
<script>
    window.downloadFileFromStream = async (fileName, streamRef) => {
        const arrayBuffer = await streamRef.arrayBuffer();
        const blob = new Blob([arrayBuffer]);
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    };
</script>
