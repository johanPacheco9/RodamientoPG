@page "/importar-vehiculos"
@using Infrastructure.Services.Importados
@using Microsoft.AspNetCore.Components.Forms
@inject ImportadosService ImportadosService
@inject IJSRuntime js
@rendermode  InteractiveServer

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            
            <div class="card shadow-sm border-0">
                <div class="card-header text-white py-3" style="background-color: #112366;">
                    <h5 class="card-title mb-0 fs-6 fw-bold">
                        <i class="bi bi-file-earmark-excel me-2"></i>Importación Masiva de Vehículos
                    </h5>
                </div>
                
                <div class="card-body p-4 text-center">
                    
                    @if (!isProcessing)
                    {
                        <!-- Carga de archivo -->
                        <div class="mb-4 p-4 border border-2 border-dashed rounded bg-light">
                            <i class="bi bi-cloud-upload text-primary display-4 d-block mb-2"></i>
                            <p class="mb-2 text-muted fw-bold">Selecciona el archivo Excel de vehículos</p>
                            <span class="badge bg-secondary mb-3">.xlsx, .xls</span>
                            
                            <div class="d-flex justify-content-center">
                                <InputFile OnChange="OnInputFileChange" class="form-control form-control-sm w-75" accept=".xlsx, .xls" />
                            </div>
                        </div>

                        @if (archivoSeleccionado != null)
                        {
                            <div class="alert alert-info d-flex align-items-center justify-content-between p-2 mb-3" style="font-size: 13px;">
                                <div>
                                    <i class="bi bi-file-earmark-check me-2"></i>
                                    <strong>@archivoSeleccionado.Name</strong> (@((archivoSeleccionado.Size / 1024.0 / 1024.0).ToString("0.00")) MB)
                                </div>
                                <button type="button" class="btn-close" style="font-size: 10px;" @onclick="LimpiarArchivo"></button>
                            </div>

                            <button type="button" class="btn btn-primary px-4 shadow-sm" @onclick="ProcesarImportacion">
                                <i class="bi bi-play-fill me-1"></i> Iniciar Importación
                            </button>
                        }
                    }
                    else
                    {
                        <!-- Spinner con Porcentaje Central -->
                        <div class="py-4">
                            <div class="position-relative d-inline-flex justify-content-center align-items-center mb-3">
                                <div class="spinner-border text-primary" style="width: 5.5rem; height: 5.5rem; border-width: 0.4em;" role="status"></div>
                                <div class="position-absolute fw-bold fs-5 text-dark">
                                    @porcentaje%
                                </div>
                            </div>

                            <h6 class="fw-bold text-dark mb-1">@estadoMensaje</h6>
                            <p class="text-muted small mb-3">Procesando y creando registros en la Base de Datos...</p>

                            <!-- Barra de Progreso -->
                            <div class="progress w-100 mb-2" style="height: 10px;">
                                <div class="progress-bar bg-success progress-bar-striped progress-bar-animated" 
                                     role="progressbar" 
                                     style="width: @porcentaje%"></div>
                            </div>
                        </div>
                    }

                    <!-- Sección de Mensajes / Errores de la última ejecución -->
                    @if (!string.IsNullOrEmpty(mensajeResultado))
                    {
                        <div class="alert @(exitoImportacion ? "alert-success" : "alert-warning") text-start mt-4" role="alert">
                            <h6 class="alert-heading fw-bold fs-6">
                                <i class="bi @(exitoImportacion ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
                                @mensajeResultado
                            </h6>
                            
                            @if (listaErrores.Any())
                            {
                                <hr class="my-2" />
                                <p class="mb-1 small fw-bold">Observaciones / Inconsistencias (@listaErrores.Count):</p>
                                <div class="overflow-auto bg-white p-2 rounded border" style="max-height: 150px; font-size: 11px;">
                                    <ul class="mb-0 ps-3 text-danger">
                                        @foreach (var err in listaErrores)
                                        {
                                            <li>@err</li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>

@code {
    private IBrowserFile? archivoSeleccionado;
    private bool isProcessing = false;
    
    private int porcentaje = 0;
    private string estadoMensaje = "Cargando archivo...";

    // Variables para el resultado de la importación
    private bool exitoImportacion = false;
    private string mensajeResultado = string.Empty;
    private List<string> listaErrores = new();

    private void OnInputFileChange(InputFileChangeEventArgs e)
    {
        archivoSeleccionado = e.File;
        mensajeResultado = string.Empty;
        listaErrores.Clear();
    }

    // Limpia SOLO la selección de archivo. Ya NO toca mensajeResultado ni listaErrores,
    // porque este método también se llamaba después de una importación exitosa,
    // borrando el reporte justo antes de que el usuario pudiera verlo.
    private void LimpiarArchivo()
    {
        archivoSeleccionado = null;
    }

    private async Task ProcesarImportacion()
    {
        if (archivoSeleccionado == null) return;

        isProcessing = true;
        porcentaje = 0;
        estadoMensaje = "Leyendo archivo Excel...";
        mensajeResultado = string.Empty;
        listaErrores.Clear();
        StateHasChanged();

        try
        {
            // Limitamos la lectura hasta 50MB
            using var stream = archivoSeleccionado.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            using var memoryStream = new MemoryStream();

            await stream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            estadoMensaje = "Validando catálogos y procesando BD...";
            StateHasChanged();

            // Progress<int> recibe el % real reportado desde el servicio mientras procesa
            // cada fila (no solo saltos fijos 10/30/60/100). InvokeAsync + StateHasChanged
            // aseguran que el render llegue al navegador aunque el callback no corra
            // en el hilo de UI de Blazor Server.
            var progreso = new Progress<int>(p =>
            {
                InvokeAsync(() =>
                {
                    porcentaje = p;
                    estadoMensaje = p switch
                    {
                        <= 20 => "Cargando catálogos...",
                        < 90 => $"Procesando registros... ({p}%)",
                        < 100 => "Guardando cambios en la base de datos...",
                        _ => "¡Finalizado!"
                    };
                    StateHasChanged();
                });
            });

            var (success, message, importados, errores) =
                await ImportadosService.ImportarDesdeExcelAsync(memoryStream, progreso);

            // Guardamos los resultados
            exitoImportacion = success;
            mensajeResultado = message;
            listaErrores = errores;

            // Antes esto llamaba a LimpiarArchivo(), que también borraba
            // mensajeResultado y listaErrores. Ahora solo se limpia la selección
            // de archivo, para que el reporte de la importación quede visible.
            if (success)
            {
                archivoSeleccionado = null;
            }
        }
        catch (Exception ex)
        {
            exitoImportacion = false;
            mensajeResultado = $"Error crítico durante la lectura del archivo: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
            porcentaje = 0;
            StateHasChanged();
        }
    }
}
