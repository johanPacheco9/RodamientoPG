@page "/"
@model Rodamiento.Pages.PLogin.LogInModel

@{
    Layout = null;
    var error = TempData["ErrorMessage"] as string;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso - Rodamiento</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --brand: #112366;
            --brand-soft: #e8edf9;
            --ink: #172033;
            --muted: #647084;
            --line: #d9e0ea;
            --ok: #1f8f5f;
            --surface: #ffffff;
            --page: #f5f7fb;
        }

        * { box-sizing: border-box; }

        body {
            min-height: 100vh;
            margin: 0;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            color: var(--ink);
            background:
                linear-gradient(120deg, rgba(17,35,102,.08), transparent 36%),
                linear-gradient(180deg, #ffffff 0%, var(--page) 100%);
        }

        .login-shell {
            min-height: 100vh;
            display: grid;
            grid-template-columns: minmax(320px, 1fr) minmax(360px, 460px);
        }

        .brand-panel {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 44px;
            background:
                linear-gradient(145deg, rgba(17,35,102,.96), rgba(22,54,105,.92)),
                url("/img/logo.png");
            background-size: cover;
            background-position: center;
            color: #fff;
        }

        .brand-mark {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            font-weight: 800;
            letter-spacing: .2px;
        }

        .brand-icon {
            width: 42px;
            height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.18);
        }

        .brand-copy {
            max-width: 620px;
        }

        .brand-copy h1 {
            font-size: clamp(2rem, 4vw, 4.3rem);
            line-height: .98;
            margin: 0 0 20px;
            font-weight: 800;
            letter-spacing: 0;
        }

        .brand-copy p {
            max-width: 520px;
            margin: 0;
            font-size: 1rem;
            line-height: 1.65;
            color: rgba(255,255,255,.78);
        }

        .status-row {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            color: rgba(255,255,255,.82);
            font-size: .86rem;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 10px;
            border: 1px solid rgba(255,255,255,.16);
            background: rgba(255,255,255,.08);
            border-radius: 8px;
        }

        .form-panel {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 36px;
        }

        .login-card {
            width: 100%;
            max-width: 390px;
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 8px;
            box-shadow: 0 18px 45px rgba(20, 32, 56, .12);
            padding: 30px;
        }

        .login-card h2 {
            font-size: 1.45rem;
            font-weight: 800;
            margin: 0;
            letter-spacing: 0;
        }

        .login-card .subtitle {
            margin: 8px 0 24px;
            color: var(--muted);
            font-size: .92rem;
        }

        .field-label {
            font-size: .78rem;
            font-weight: 700;
            color: #364055;
            margin-bottom: 7px;
        }

        .input-wrap {
            position: relative;
        }

        .input-wrap i {
            position: absolute;
            top: 50%;
            left: 12px;
            transform: translateY(-50%);
            color: #738098;
            font-size: .95rem;
        }

        .form-control {
            height: 44px;
            border-radius: 8px;
            border-color: var(--line);
            padding-left: 38px;
            font-size: .94rem;
        }

        .form-control:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 4px rgba(17,35,102,.10);
        }

        .btn-login {
            height: 44px;
            border-radius: 8px;
            border: 0;
            background: var(--brand);
            color: #fff;
            font-weight: 800;
            width: 100%;
        }

        .btn-login:hover { background: #19347e; color: #fff; }

        .support-line {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            margin-top: 20px;
            padding-top: 18px;
            border-top: 1px solid var(--line);
            color: var(--muted);
            font-size: .82rem;
        }

        .alert {
            border-radius: 8px;
            font-size: .86rem;
        }

        @@media (max-width: 860px) {
            .login-shell { grid-template-columns: 1fr; }
            .brand-panel {
                min-height: 260px;
                padding: 28px;
            }
            .brand-copy h1 { font-size: 2rem; }
            .status-row { display: none; }
            .form-panel { padding: 24px; align-items: flex-start; }
        }
    </style>
</head>
<body>
    <main class="login-shell">
        <section class="brand-panel">
            <div class="brand-mark">
                <span class="brand-icon"><i class="bi bi-bank2"></i></span>
                <span>Rodamiento</span>
            </div>

            <div class="brand-copy">
                <h1>Impuesto vehicular</h1>
                <p>Ingreso seguro al sistema de gestión de liquidaciones, cartera, pagos y procesos administrativos.</p>
            </div>

            <div class="status-row">
                <span class="status-pill"><i class="bi bi-shield-check"></i> Acceso institucional</span>
                <span class="status-pill"><i class="bi bi-database-check"></i> PostgreSQL conectado</span>
            </div>
        </section>

        <section class="form-panel">
            <div class="login-card">
                <h2>Iniciar sesión</h2>
                <p class="subtitle">Usa tu usuario interno para continuar.</p>

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger py-2" role="alert">
                        Usuario o contraseña inválidos.
                    </div>
                }

                <form method="post" autocomplete="off">
                    <div class="mb-3">
                        <label for="UserName" class="field-label">Usuario</label>
                        <div class="input-wrap">
                            <i class="bi bi-person"></i>
                            <input id="UserName" name="UserName" type="text" class="form-control" maxlength="50" required autofocus />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="pass" class="field-label">Contraseña</label>
                        <div class="input-wrap">
                            <i class="bi bi-lock"></i>
                            <input id="pass" name="pass" type="password" class="form-control" maxlength="64" required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-login">
                        Ingresar
                    </button>
                </form>

                <div class="support-line">
                    <span>Dataset Software</span>
                    <span>v2.0</span>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
