@page "/Uvts"
@using Domain.Models
@using Infrastructure.Services.Uvts

@inject UvtService UvtService
@inject IJSRuntime JSRuntime
@rendermode  InteractiveServer

<div class="container-fluid py-4">
    <!-- Encabezado de la Página -->
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 pb-3 border-bottom gap-3">
        <div>
            <h1 class="h4 fw-bold text-dark mb-1">Histórico de Valores UVT</h1>
            <p class="text-muted small mb-0">Gestión de la Unidad de Valor Tributario parametrizada para la liquidación anual de impuestos y sanciones.</p>
        </div>
        <button type="button" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm" @onclick="() => AbrirModalCrear(false)">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-circle-fill" viewBox="0 0 16 16">
                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM8.5 4.5a.5.5 0 0 0-1 0v3h-3a.5.5 0 0 0 0 1h3v3a.5.5 0 0 0 1 0v-3h3a.5.5 0 0 0 0-1h-3v-3z"/>
            </svg>
            Registrar UVT Anual
        </button>
    </div>

    <!-- Barra de Filtros y Búsqueda -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <div class="row align-items-center">
                <div class="col-12 col-md-5 col-lg-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                            </svg>
                        </span>
                        <input type="text" class="form-control border-start-0 ps-0 text-sm" @bind="_textoBusqueda" @bind:event="oninput" @onkeyup="BuscarUvtPorFecha"
                               placeholder="Buscar por año o fecha específica..."/>
                        @if (!string.IsNullOrEmpty(_textoBusqueda))
                        {
                            <button class="btn btn-outline-secondary border-start-0 border-end-0" type="button" @onclick="LimpiarBusqueda">×</button>
                        }
                        <button @onclick="BuscarUvtPorFecha" class="btn btn-secondary px-3" type="button">Buscar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Contenedor Principal de la Tabla -->
    <div class="card border-0 shadow-sm overflow-hidden position-relative">
        @if (_isLoading)
        {
            <div class="position-absolute inset-0 bg-white bg-opacity-75 d-flex justify-content-center align-items-center" style="z-index: 10; min-height: 250px;">
                <div class="text-center">
                    <div class="spinner-border text-primary mb-2" role="status"></div>
                    <div class="text-muted small fw-medium">Cargando histórico fiscal...</div>
                </div>
            </div>
        }

        <div class="table-responsive" style="min-height: 250px;">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light border-bottom text-uppercase fs-7 text-muted tracking-wider">
                    <tr>
                        <th class="ps-4 py-3" style="width: 100px;">Código (ID)</th>
                        <th class="py-3">Vigencia Desde</th>
                        <th class="py-3">Vigencia Hasta</th>
                        <th class="py-3">Año Fiscal</th>
                        <th class="pe-4 py-3 text-end" style="width: 220px;">Valor Oficial de la UVT</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (_listadoUvts == null || !_listadoUvts.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <div class="py-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" class="bi bi-inbox text-muted mb-2" viewBox="0 0 16 16">
                                        <path d="M4.98 4a.5.5 0 0 0-.39.188L1.54 8H6a.5.5 0 0 1 .5.5 1.5 1.5 0 1 0 3 0A.5.5 0 0 1 10 8h4.46l-3.05-3.812A.5.5 0 0 0 11.02 4H4.98zm-1.17-.437A1.5 1.5 0 0 1 4.98 3h6.04a1.5 1.5 0 0 1 1.17.563l3.7 4.625a.5.5 0 0 1 .11.312V13a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V8.063a.5.5 0 0 1 .11-.312l3.7-4.625z"/>
                                    </svg>
                                    <p class="mb-0 fs-6">No se encontraron registros de UVT en el sistema.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var uvt in ObtenerItemsPaginados())
                        {
                            <tr @onclick="() => OnRowSelect(uvt)" style="cursor: pointer;" class="transition-all">
                                <td class="ps-4 fw-medium text-secondary">#@uvt.Id</td>
                                <td><span class="badge bg-light text-dark border px-2 py-1.5 fw-normal">@uvt.FechaDesde.ToString("dd/MM/yyyy")</span></td>
                                <td><span class="badge bg-light text-dark border px-2 py-1.5 fw-normal">@uvt.FechaHasta.ToString("dd/MM/yyyy")</span></td>
                                <td class="fw-bold text-dark">@uvt.FechaDesde.Year</td>
                                <td class="pe-4 text-end">
                                    <span class="fs-6 fw-bold text-success px-2 py-1 rounded bg-success-subtle border border-success border-opacity-20">
                                        @uvt.Valor.ToString("C0")
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginación Mejorada -->
        @if (TotalPaginas > 1)
        {
            <div class="card-footer bg-white border-top d-flex flex-column flex-sm-row justify-content-between align-items-center px-4 py-3 gap-3">
                <div class="text-muted small">
                    Mostrando del <span class="fw-semibold text-dark">@(((PaginaActual - 1) * TamanoPagina) + 1)</span> al 
                    <span class="fw-semibold text-dark">@(Math.Min(PaginaActual * TamanoPagina, _listadoUvts.Count))</span> de 
                    <span class="fw-semibold text-dark">@_listadoUvts.Count</span> registros fiscales.
                </div>
                <nav aria-label="Navegación de páginas">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(PaginaActual == 1 ? "disabled" : "")">
                            <button class="page-link px-3" @onclick="() => CambiarPagina(PaginaActual - 1)">Anterior</button>
                        </li>
                        @for (int i = 1; i <= TotalPaginas; i++)
                        {
                            var paginaAsignada = i;
                            <li class="page-item @(PaginaActual == paginaAsignada ? "active" : "")">
                                <button class="page-link px-3" @onclick="() => CambiarPagina(paginaAsignada)">@paginaAsignada</button>
                            </li>
                        }
                        <li class="page-item @(PaginaActual == TotalPaginas ? "disabled" : "")">
                            <button class="page-link px-3" @onclick="() => CambiarPagina(PaginaActual + 1)">Siguiente</button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

<!-- Modal 100% Nativo de Bootstrap para Creación/Edición -->
@if (_mostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(15, 23, 42, 0.4); backdrop-filter: blur(4px); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-dark text-white px-4 py-3 border-bottom-0">
                    <h5 class="modal-title fs-6 fw-bold">
                        @(_esModoEditar ? "Modificar Configuración UVT" : "Registrar Nueva UVT Anual")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" aria-label="Close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body p-4 bg-light bg-gradient">
                    @if (_uvtFormulario != null)
                    {
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label text-secondary small fw-bold mb-1">Código Interno del Registro</label>
                                <input type="text" class="form-control bg-white-50 border-secondary-subtle"
                                       value="@(_esModoEditar ? $"Registro Único #{_uvtFormulario.Id}" : "ASIGNACIÓN AUTOMÁTICA EN BD")" readonly disabled>
                            </div>
                            
                            <div class="col-6">
                                <label class="form-label text-secondary small fw-bold mb-1">Inicio Vigencia</label>
                                <input type="date" class="form-control border-secondary-subtle font-monospace fw-bold" 
                                       @bind="_uvtFormulario.FechaDesde" @bind:format="yyyy-MM-dd">
                            </div>
                            
                            <div class="col-6">
                                <label class="form-label text-secondary small fw-bold mb-1">Fin Vigencia</label>
                                <input type="date" class="form-control border-secondary-subtle font-monospace fw-bold" 
                                       @bind="_uvtFormulario.FechaHasta" @bind:format="yyyy-MM-dd">
                            </div>
                            
                            <div class="col-12 mt-3">
                                <label class="form-label text-secondary small fw-bold mb-1">Valor Oficial establecido en Pesos ($)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 text-success fw-bold">$</span>
                                    <input type="number" step="1" class="form-control border-start-0 ps-1 fw-bold text-success fs-5 font-monospace"
                                           placeholder="0" @bind="_uvtFormulario.Valor">
                                </div>
                                <div class="form-text text-muted fs-7">Verifica el decreto oficial de la DIAN antes de almacenar el valor en pesos.</div>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer px-4 py-3 bg-white border-top-0 gap-2">
                    <button type="button" class="btn btn-outline-secondary px-3 btn-sm" style="border-radius: 6px;" @onclick="CerrarModal">
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-success px-4 btn-sm shadow-sm" style="border-radius: 6px;" @onclick="ProcesarGuardado">
                        <i class="bi bi-check-circle-fill me-1"></i>
                        <span>@(_esModoEditar ? "Guardar Cambios" : "Crear Registro")</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .fs-7 { font-size: 0.75rem; }
    .py-1.5 { padding-top: 0.375rem; padding-bottom: 0.375rem; }
    .tracking-wider { letter-spacing: 0.05em; }
    .bg-white-50 { background-color: rgba(255, 255, 255, 0.5) !important; }
    .transition-all { transition: all 0.15s ease-in-out; }
    .table-hover tbody tr:hover { background-color: rgba(13, 110, 253, 0.03) !important; }
</style>